# ============================================
# Trading System Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then load before running:
#   source .env  (Linux/Mac)
#   or set in your system environment (Windows)
# ============================================

# --- Base Currency ---
# Set to "USD" for Binance USDT trading, or "INR" for WazirX INR trading
BASE_CURRENCY=USD

# --- Binance API (for USD/USDT-based BTC trading) ---
# Get your API keys from: https://www.binance.com/en/my/settings/api-management
# Use testnet keys first: https://testnet.binance.vision/
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET=true

# --- WazirX API (for INR-based BTC trading) ---
# Get your API keys from: https://wazirx.com/settings/keys
WAZIRX_API_KEY=your_wazirx_api_key_here
WAZIRX_API_SECRET=your_wazirx_api_secret_here

# --- Delta Exchange API (for INR + USDT trading, India-based) ---
# Get your API keys from: https://www.delta.exchange/app/account/api-keys
# Testnet keys from: https://testnet.delta.exchange/
DELTA_API_KEY=your_delta_api_key_here
DELTA_API_SECRET=your_delta_api_secret_here
DELTA_TESTNET=true

# --- XM Broker (MetaTrader 5 — for Gold XAU/USD + BTC/USD CFD trading) ---
# XM accepts clients from India. Sign up at: https://www.xm.com/register
# After account creation, download MT5 and note your login credentials.
# Demo account: https://www.xm.com/demo-account (recommended to start)
XM_MT5_LOGIN=83034969
XM_MT5_PASSWORD=Lutu@871987
XM_MT5_SERVER=XMGlobal-MT5 4
XM_DEMO=true

# --- Alpha Vantage API (extra data feed fallback — free, 5 calls/min) ---
# Get a free API key at: https://www.alphavantage.co/support/#api-key
# Provides reliable BTC and Gold (XAU/USD) historical data
# Optional — system works without it (uses Binance → CoinGecko → Yahoo)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# --- Optional: Slack Alerts ---
# Create a Slack webhook at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# --- Trading Parameters ---
INITIAL_BALANCE=100000
TRADING_MODE=paper
LOG_LEVEL=INFO
MAX_PORTFOLIO_EXPOSURE_PCT=35

# --- Scan Interval ---
# How often the algo checks for trading opportunities (in seconds)
# Default is 30 seconds. Set lower for faster scanning (min: 10)
SCAN_INTERVAL_SECONDS=30

# --- Leverage ---
# Leverage multiplier for live trading (paper mode always uses 1x)
# 1 = no leverage, 25 = 25x leverage
# WARNING: Higher leverage = higher risk. A small price move can liquidate your position.
LEVERAGE=25

# --- Dollar-based risk controls for paper/live runtime ---
# Set to 0 to use strategy/ATR/percentage stops.
FIXED_STOP_LOSS_USD=0
FIXED_TAKE_PROFIT_USD=0
TRAILING_STOP_ACTIVATION_USD=0
TRAILING_STOP_DISTANCE_USD=0
